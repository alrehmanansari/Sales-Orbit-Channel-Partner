# Server
PORT=3000
NODE_ENV=development

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=sales_orbit
DB_USER=your_db_user
DB_PASSWORD=your_db_password

# JWT
JWT_SECRET=generate_a_long_random_secret_here
JWT_EXPIRES_IN=7d

# CORS
FRONTEND_URL=http://localhost:8080

# File uploads
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760
